rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: projects
    // Document ID: auto-generated or slug
    // Fields:
    //   - slug: string (required)
    //   - title: string (required)
    //   - type: string (required)
    //   - tools: string
    //   - location: string
    //   - image: string (required)
    //   - description: string (required)
    //   - details: list of maps
    //   - gallery: list of strings
    //   - createdAt: timestamp
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (request.auth.token.email.lower() == "rocottier82@gmail.com" && request.auth.token.email_verified == true);
    }

    function isValidProject(data) {
      return data.keys().hasAll(['slug', 'title', 'type', 'image', 'description']) &&
             data.slug is string && data.slug.size() > 0 &&
             data.title is string && data.title.size() > 0 &&
             data.type in ['Residential', 'Commercial'] &&
             data.image is string &&
             data.description is string;
    }

    match /projects/{projectId} {
      allow read: if true; // Publicly readable portfolio
      allow create, update, delete: if isAdmin() && isValidProject(request.resource.data);
    }
  }
}
